# crie um algoritimo que leia um numero e mostre o seu dobro triplo e a raiz quadrada dele

n = int(input('coloca um numero: '))

d = n * 2
t = n * 3
r = n ** 0.5
print('O o dobro do seu numero e  {} '.format(d))
print('o triplo do seu numero e  {} '.format(t))
print('a raiz do seu numero e  {} '.format(r))


